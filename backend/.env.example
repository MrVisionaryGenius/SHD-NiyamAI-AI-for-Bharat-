# NiyamAI Risk Checker - Environment Variables Template
# Copy this file to .env and fill in your values

# Database Configuration
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_NAME=niyamai
DB_USER=niyamai_user
DB_PASSWORD=your-secure-password
DB_PORT=5432
DB_SSL=true

# VPC Configuration (required for Lambda deployment in private subnets)
VPC_ID=vpc-xxxxxxxx
PRIVATE_SUBNET_1=subnet-xxxxxxxx
PRIVATE_SUBNET_2=subnet-yyyyyyyy
PRIVATE_ROUTE_TABLE_ID=rtb-xxxxxxxx

# AI Service Configuration
AI_API_KEY=your-openai-or-claude-api-key
AI_API_PROVIDER=openai  # or 'claude'

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# Stage Configuration
STAGE=dev  # or 'prod'

# Optional: Custom Domain
# CUSTOM_DOMAIN=api.niyamai.com
# CERTIFICATE_ARN=arn:aws:acm:us-east-1:123456789012:certificate/xxxxx
