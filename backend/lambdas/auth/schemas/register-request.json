{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "email": {
            "type": "string",
            "format": "email",
            "description": "User email address"
        },
        "password": {
            "type": "string",
            "minLength": 8,
            "description": "User password (minimum 8 characters)"
        },
        "businessName": {
            "type": "string",
            "description": "Optional business name"
        }
    },
    "required": [
        "email",
        "password"
    ],
    "additionalProperties": false
}